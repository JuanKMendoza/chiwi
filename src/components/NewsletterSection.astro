---
---

<!-- Sección Newsletter Mejorada y Segura -->
<section class="relative w-full py-20 px-4 overflow-hidden">
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#F4B08A] via-[#F49C6E] to-[#E1814C]"
  ></div>
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 20px 20px;"
  ></div>

  <div
    class="relative max-w-3xl mx-auto flex flex-col items-center text-center gap-8"
  >
    <div class="space-y-4">
      <span
        class="inline-block bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-semibold text-white"
      >
        Únete a la familia Chiwi
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        No te pierdas nuestras ediciones especiales
      </h2>
    </div>

    <p class="text-white/90 leading-relaxed text-lg max-w-2xl">
      Sé el primero en conocer nuestros nuevos diseños. Suscríbete y recibe
      descuentos exclusivos, lanzamientos anticipados y tips para que tus
      velitas cuenten aún más historias.
    </p>

    <!-- ✅ Newsletter con protección -->
    <form
      id="newsletter-form"
      class="w-full flex flex-col md:flex-row items-center gap-4"
      novalidate
    >
      <!-- 🕵️ Honeypot invisible (anti-bots) -->
      <input type="text" name="nickname" style="display:none" tabindex="-1" autocomplete="off" />

      <input
        type="email"
        name="email"
        placeholder="tu@correo.com"
        required
        aria-label="Correo electrónico"
        autocomplete="off"
        class="w-full md:flex-1 px-6 py-4 rounded-full border-2 border-white/30 bg-white/90 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-white focus:bg-white font-medium text-gray-900"
      />

      <button
        type="submit"
        aria-label="Suscribirse al newsletter"
        class="group flex items-center justify-center gap-3 bg-white text-[#E1814C] font-bold px-8 py-4 rounded-full shadow-xl hover:scale-105 transition-all duration-300 w-full md:w-auto"
      >
        <ion-icon
          name="paper-plane-outline"
          class="text-xl group-hover:translate-x-1 transition-transform"
        ></ion-icon>
        Suscribirme
      </button>
    </form>

    <p class="text-white/70 text-sm">
      Respetamos tu privacidad. Sin spam, solo amor y velas kawaii.
    </p>
  </div>
</section>

<!-- ✅ JS seguro (protege sin backend) -->
<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();

    const emailInput = form.querySelector('[name="email"]') as HTMLInputElement;
    const trapInput = form.querySelector('[name="nickname"]') as HTMLInputElement;

    const email = emailInput.value.trim();
    const trap = trapInput.value.trim();

    if (trap !== '') return; // Bot detectado

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      alert('Por favor, ingresa un correo válido.');
      return;
    }

    const safeEmail = email.replace(/[<>"]/g, '');
    // Meta Pixel: Lead — optimiza campañas de captación de emails
    if (typeof fbq === 'function') {
      fbq('track', 'Lead', { content_name: 'Newsletter Chiwi' });
    }
    alert(`¡Gracias! Te avisaremos a ${safeEmail} cuando haya novedades 🌟`);
    form.reset();
  });
</script>
