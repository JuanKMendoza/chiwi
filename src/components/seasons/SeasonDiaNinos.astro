---
import { Image } from "astro:assets";
import { products } from "../../data/products";

const diaDeNinosProducts = products.filter(p =>
  ["capibara-mood-relax", "capibara-cute", "familia-de-ositos"].includes(p.slug)
);
---

<!-- Sección Día del Niño — activa todo abril -->
<section class="relative py-24 overflow-hidden bg-gradient-to-b from-yellow-50 via-green-50 to-pink-50">

  <!-- Elementos decorativos flotantes -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute text-5xl opacity-20" style="top: 10%; left: 5%; animation: float-ninos 7s ease-in-out infinite;">🎈</div>
    <div class="absolute text-4xl opacity-20" style="top: 60%; right: 8%; animation: float-ninos 5s ease-in-out infinite; animation-delay: 1s;">🌟</div>
    <div class="absolute text-5xl opacity-20" style="bottom: 20%; left: 15%; animation: float-ninos 8s ease-in-out infinite; animation-delay: 2s;">🎠</div>
    <div class="absolute text-4xl opacity-20" style="top: 30%; right: 20%; animation: float-ninos 6s ease-in-out infinite; animation-delay: 0.5s;">🧸</div>
    <div class="absolute text-3xl opacity-20" style="bottom: 40%; right: 5%; animation: float-ninos 9s ease-in-out infinite; animation-delay: 3s;">✨</div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#F5DF90] to-[#FF8F8F] text-[#7B4F3A] font-bold px-6 py-2 rounded-full text-sm mb-6">
        🎉 Solo en Abril
      </div>
      <h2 class="text-5xl md:text-6xl font-black text-[#7B4F3A] mb-4">
        El Día del Niño más
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-pink-500">✨kawaii✨</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Para el niño o niña que llevas dentro. Velitas hechas con amor, perfectas para regalar o coleccionar este 26 de abril.
      </p>
    </div>

    <!-- Grid de productos -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-12">
      {diaDeNinosProducts.map((product) => (
        <article class="bg-white rounded-2xl shadow-lg hover:-translate-y-2 hover:shadow-xl transition-all duration-300 border-t-4 border-[#78C4A8] overflow-hidden">
          <a
            href={`/productos/${product.slug}`}
            class="block"
            data-track-event="season_cta_click"
            data-track-content-name={product.name}
            data-track-content-category="dia-del-nino"
            data-track-content-id={product.slug}
            data-track-source-section="season_ninos_product_card"
            data-track-campaign="dia-del-nino"
            data-track-value={String(product.price)}
          >
            <div class="relative overflow-hidden">
              <Image
                src={product.image}
                alt={product.alt}
                class="w-full h-64 object-cover"
                width={800}
                height={800}
                format="webp"
                loading="lazy"
              />
              <span class="absolute top-3 left-3 bg-[#F5DF90] text-[#7B4F3A] text-xs font-bold px-3 py-1 rounded-full">
                🐾 Kawaii
              </span>
            </div>
          </a>
          <div class="p-5 space-y-3">
            <h3 class="font-bold text-lg text-gray-900">{product.name}</h3>
            <p class="text-sm text-gray-600">{product.description}</p>
            <p class="text-2xl font-bold text-[#F97316]">
              ${product.price.toLocaleString("es-CO")}
            </p>
            <a
              href={`https://wa.me/573102278592?text=Hola!%20Quiero%20el%20${encodeURIComponent(product.name)}%20para%20el%20D%C3%ADa%20del%20Ni%C3%B1o%20%F0%9F%8E%88`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full bg-gradient-to-r from-[#FF8F8F] to-[#F4B08A] text-white font-semibold px-4 py-2.5 rounded-full hover:scale-105 transition-all"
              data-track-event="season_cta_click"
              data-track-content-name={product.name}
              data-track-content-category="dia-del-nino"
              data-track-content-id={product.slug}
              data-track-source-section="season_ninos_whatsapp_button"
              data-track-campaign="dia-del-nino"
              data-track-value={String(product.price)}
            >
              <ion-icon name="logo-whatsapp" class="text-xl" aria-hidden="true"></ion-icon>
              Pedir velita
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Bloque de confianza -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="text-center p-6 bg-white/70 rounded-2xl shadow-sm">
        <span class="text-4xl mb-3 block">🎁</span>
        <h4 class="font-bold text-[#7B4F3A] mb-2">100% Personalizable</h4>
        <p class="text-sm text-gray-600">Puedes agregar nombre o dedicatoria</p>
      </div>
      <div class="text-center p-6 bg-white/70 rounded-2xl shadow-sm">
        <span class="text-4xl mb-3 block">🌿</span>
        <h4 class="font-bold text-[#7B4F3A] mb-2">Cera natural</h4>
        <p class="text-sm text-gray-600">Segura para niños y mascotas</p>
      </div>
      <div class="text-center p-6 bg-white/70 rounded-2xl shadow-sm">
        <span class="text-4xl mb-3 block">🚚</span>
        <h4 class="font-bold text-[#7B4F3A] mb-2">Envío a toda Colombia</h4>
        <p class="text-sm text-gray-600">Llega antes del 26 de abril</p>
      </div>
    </div>

    <!-- CTA Final -->
    <div class="text-center">
      <a
        href="https://wa.me/573102278592?text=Hola!%20Quiero%20ver%20los%20dise%C3%B1os%20kawaii%20para%20el%20D%C3%ADa%20del%20Ni%C3%B1o"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-gradient-to-r from-orange-500 to-pink-500 text-white font-bold px-10 py-5 rounded-full text-lg hover:scale-105 hover:shadow-2xl hover:shadow-orange-500/30 transition-all duration-300"
        data-track-event="season_cta_click"
        data-track-content-name="Disenos kawaii para el Dia del Nino"
        data-track-content-category="dia-del-nino"
        data-track-source-section="season_ninos_final_cta"
        data-track-campaign="dia-del-nino"
      >
        <ion-icon name="logo-whatsapp" class="text-2xl" aria-hidden="true"></ion-icon>
        Ver todos los diseños kawaii 🎈
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes float-ninos {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    [style*="float-ninos"] { animation: none !important; }
  }
</style>
