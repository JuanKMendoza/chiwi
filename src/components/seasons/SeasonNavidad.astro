    },
    {
      name: "Muñeco de Nieve Kawaii",
      description:
        "Vela fotoluminiscente con diseño kawaii de muñeco de nieve",
      image: christmasProduct1Url,
      price: "19900",
      validUntil: "2025-12-25",
    },
    {
      name: "Pack Dúo Navideño",
      description: "Pack de dos velas fotoluminiscentes navideñas kawaii",
      image: christmasProduct1Url,
      price: "34900",
      validUntil: "2025-12-25",
    },
  ]}
/>

<style>
  /* Colores oro/dorado personalizados */
  .text-gold-400 {
    color: #fbbf24;
  }
  .from-gold-500 {
    --tw-gradient-from: #f59e0b;
  }
  .to-gold-500 {
    --tw-gradient-to: #f59e0b;
  }
  .to-gold-400 {
    --tw-gradient-to: #fbbf24;
  }
  .border-gold-400 {
    border-color: #fbbf24;
  }
  .border-gold-500 {
    border-color: #f59e0b;
  }
  .text-gold-200 {
    color: #fde68a;
  }
  .from-gold-800 {
    --tw-gradient-from: #92400e;
  }
  .hover\:shadow-gold-500\/50:hover {
    --tw-shadow-color: rgb(245 158 11 / 0.5);
  }

  /* Fondo de copos de nieve SIMPLIFICADO */
  .snowflakes-background {
    background-image: radial-gradient(2px 2px at 25% 35%, white, transparent),
      radial-gradient(1px 1px at 75% 15%, white, transparent),
      radial-gradient(1px 1px at 50% 70%, white, transparent),
      radial-gradient(2px 2px at 15% 80%, white, transparent),
      radial-gradient(1px 1px at 85% 60%, white, transparent);
    background-size: 200% 200%;
    animation: snowfall 10s ease-in-out infinite;
    opacity: 0.4;
  }

  @keyframes snowfall {
    0% {
      background-position: 0% 0%;
      opacity: 0.3;
    }
    50% {
      background-position: 100% 100%;
      opacity: 0.6;
    }
    100% {
      background-position: 0% 0%;
      opacity: 0.3;
    }
  }

  /* Elementos flotantes navideños OPTIMIZADOS */
  .christmas-float {
    position: absolute;
    font-size: 3rem;
    animation: float-christmas 6s ease-in-out infinite;
    opacity: 0.3;
    filter: drop-shadow(0 0 8px rgba(239, 68, 68, 0.4));
  }

  @keyframes float-christmas {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-25px) rotate(8deg);
    }
  }

  /* Pulso sutil OPTIMIZADO */
  @keyframes pulse-subtle {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.85;
      transform: scale(1.03);
    }
  }

  .animate-pulse-subtle {
    animation: pulse-subtle 4s ease-in-out infinite;
  }

  /* Bounce sutil OPTIMIZADO */
  @keyframes bounce-subtle {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  .animate-bounce-subtle {
    animation: bounce-subtle 3s ease-in-out infinite;
  }

  /* Gradiente fluido */
  @keyframes gradient-flow {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .animate-gradient-flow {
    background-size: 200% 200%;
    animation: gradient-flow 4s ease infinite;
  }

  /* Efecto de brillo OPTIMIZADO */
  @keyframes glow {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.8;
    }
  }

  .animate-glow {
    animation: glow 3s ease-in-out infinite;
  }

  /* Tarjeta navideña */
  .christmas-card {
    animation: fadeInUp 0.8s ease-out;
    animation-fill-mode: both;
  }

  .christmas-card:nth-child(1) {
    animation-delay: 0.1s;
  }

  .christmas-card:nth-child(2) {
    animation-delay: 0.2s;
  }

  .christmas-card:nth-child(3) {
    animation-delay: 0.3s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Optimización para usuarios con prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .christmas-float,
    .animate-pulse-subtle,
    .animate-bounce-subtle,
    .animate-gradient-flow,
    .animate-glow {
      animation: none !important;
    }

    .christmas-card {
      animation: none !important;
      opacity: 1 !important;
    }

    .snowflakes-background {
      animation: none !important;
      opacity: 0.3 !important;
    }
  }

  /* Optimización de rendimiento */
  .group:hover .group-hover\:scale-105 {
    will-change: transform;
  }
</style>

<script>
  // Contador regresivo con lazy loading
  const christmasSection = document.querySelector(".christmas-section");

  if (christmasSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            initChristmasCountdown();
            observer.disconnect();
          }
        });
      },
      {
        rootMargin: "50px",
      }
    );

    observer.observe(christmasSection);
  }

  function initChristmasCountdown() {
    updateChristmasCountdown();
    setInterval(updateChristmasCountdown, 60000); // Actualizar cada minuto
  }

  function updateChristmasCountdown() {
    const now = new Date();
    const currentYear = now.getFullYear();
    const christmas = new Date(currentYear, 11, 25, 0, 0, 0); // Dic 25, 00:00:00

    // Si ya pasó Navidad este año, calcular para el próximo
    if (now > christmas) {
      christmas.setFullYear(currentYear + 1);
    }

    const diff = christmas.getTime() - now.getTime();

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor(
      (diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)
    );
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

    const daysEl = document.querySelector(".christmas-section .countdown-days");
    const hoursEl = document.querySelector(".christmas-section .countdown-hours");
    const minutesEl = document.querySelector(".christmas-section .countdown-minutes");

    if (daysEl) daysEl.textContent = days.toString().padStart(2, "0");
    if (hoursEl) hoursEl.textContent = hours.toString().padStart(2, "0");
    if (minutesEl)
      minutesEl.textContent = minutes.toString().padStart(2, "0");
  }
</script>
