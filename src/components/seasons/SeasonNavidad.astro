---
import Image from "astro/components/Image.astro";
import SeasonalProductSchema from "../SeasonalProductSchema.astro";
import christmasProduct1 from "../../assets/images/farolito_solo.webp";
import christmasProduct2 from "../../assets/images/Farolitos_uno.webp";
import christmasProduct3 from "../../assets/images/bolitas_velitas_con_nombres.webp";
import fantasmasChiwiImg from "../../assets/images/fantasma_chiwi.jpg";

const baseUrl = Astro.site?.href || "https://chiwicolombia.com";
const christmasProduct1Url = new URL(christmasProduct1.src, baseUrl).href;
---

<!-- Sección Productos de Temporada - NAVIDAD -->
<section
  class="christmas-section relative py-24 overflow-hidden bg-gradient-to-b from-red-900 via-green-900 to-red-950"
>
  <!-- Fondo con copos de nieve -->
  <div class="absolute inset-0 snowflakes-background"></div>

  <!-- Elementos decorativos flotantes REDUCIDOS -->
  <div
    class="absolute inset-0 pointer-events-none overflow-hidden"
    aria-hidden="true"
  >
    <div
      class="christmas-float"
      style="top: 15%; left: 8%; animation-delay: 0s;"
    >
      🎄
    </div>
    <div
      class="christmas-float"
      style="top: 70%; right: 12%; animation-delay: 1.5s;"
    >
      ⛄
    </div>
    <div
      class="christmas-float"
      style="bottom: 25%; left: 18%; animation-delay: 3s;"
    >
      ❄️
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4">
    <!-- Header de la sección -->
    <div class="text-center mb-16 relative">
      <!-- Badge de temporada -->
      <div
        class="inline-flex items-center gap-2 bg-red-500/20 backdrop-blur-sm border-2 border-red-400 rounded-full px-6 py-2 mb-10 animate-pulse-subtle"
      >
        <span class="text-2xl" aria-hidden="true">🎄</span>
        <span
          class="text-red-300 font-bold text-sm uppercase tracking-wider"
        >
          Edición Limitada - Diciembre 2025
        </span>
        <span class="text-2xl" aria-hidden="true">🎅</span>
      </div>

      <!-- Espacio adicional -->
      <div class="h-6"></div>

      <!-- Título principal con efecto de brillo -->
      <h2
        class="text-5xl md:text-7xl font-black text-white mb-6 relative inline-block"
      >
        <span class="relative z-10">
          Especial
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 via-green-400 to-gold-400 animate-gradient-flow"
          >
            Navidad
          </span>
        </span>
        <div
          class="absolute -inset-2 bg-gradient-to-r from-red-500/30 to-green-500/30 blur-2xl animate-glow"
        >
        </div>
      </h2>

      <!-- Subtítulo -->
      <p
        class="text-xl md:text-2xl text-green-200 max-w-3xl mx-auto leading-relaxed"
      >
        Velas mágicas que <span class="text-red-300 font-bold"
          >brillan en la oscuridad</span
        >. Perfectas para decorar tu Navidad con espíritu kawaii.
      </p>

      <!-- Contador regresivo -->
      <div
        class="mt-8 inline-flex items-center gap-3 bg-black/40 backdrop-blur-md rounded-full px-6 py-3 border border-red-500/30"
      >
        <ion-icon
          name="time-outline"
          class="text-2xl text-red-400"
          aria-hidden="true"></ion-icon>
        <span class="text-red-300 font-semibold"
          >Cuenta regresiva para Navidad</span
