        </div>
      </div>
    </div>

    <!-- Grid de productos de temporada -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      <!-- Producto 1: Farolitos -->
      <article class="group relative christmas-card">
        <!-- Badge "NUEVO" -->
