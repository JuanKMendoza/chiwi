        <div class="flex gap-2" role="timer" aria-live="polite">
          <div class="bg-red-500/20 rounded px-2 py-1">
            <span
              class="text-white font-bold text-sm countdown-days"
              aria-label="días">00</span
            >
          </div>
          <span class="text-white" aria-hidden="true">:</span>
          <div class="bg-red-500/20 rounded px-2 py-1">
            <span
              class="text-white font-bold text-sm countdown-hours"
              aria-label="horas">00</span
