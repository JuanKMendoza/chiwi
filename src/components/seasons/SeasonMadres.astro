---
import { Image } from "astro:assets";
import { products } from "../../data/products";

const madresProducts = products.filter(p =>
  ["cajita-recuerdame", "gatito-personalizado", "perrito-cocker"].includes(p.slug)
);
---

<!-- Sección Día de las Madres — activa todo mayo -->
<section class="relative py-24 overflow-hidden bg-gradient-to-b from-pink-50 via-purple-50 to-rose-50">

  <!-- Elementos decorativos flotantes -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute text-5xl opacity-20" style="top: 10%; left: 5%; animation: float-madres 7s ease-in-out infinite;">💐</div>
    <div class="absolute text-4xl opacity-20" style="top: 55%; right: 8%; animation: float-madres 5s ease-in-out infinite; animation-delay: 1s;">🌸</div>
    <div class="absolute text-5xl opacity-20" style="bottom: 20%; left: 15%; animation: float-madres 8s ease-in-out infinite; animation-delay: 2s;">💖</div>
    <div class="absolute text-4xl opacity-20" style="top: 35%; right: 20%; animation: float-madres 6s ease-in-out infinite; animation-delay: 0.5s;">🌷</div>
    <div class="absolute text-3xl opacity-20" style="bottom: 45%; right: 5%; animation: float-madres 9s ease-in-out infinite; animation-delay: 3s;">✨</div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#C4A0D8] to-[#E8909A] text-white font-bold px-6 py-2 rounded-full text-sm mb-6">
        🌸 Mayo, mes de las madres
      </div>
      <h2 class="text-5xl md:text-6xl font-black text-[#7B4F3A] mb-4">
        Para la mujer que
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#C4A0D8] to-[#E8909A]">más amamos</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Cada mamá se merece un regalo hecho a mano, con amor real. Una velita Chiwi no se olvida.
      </p>
    </div>

    <!-- Grid de productos -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-12">
      {madresProducts.map((product) => (
        <article class="bg-white rounded-2xl shadow-lg hover:-translate-y-2 hover:shadow-xl transition-all duration-300 border-t-4 border-[#C4A0D8] overflow-hidden">
          <a href={`/productos/${product.slug}`} class="block">
            <div class="relative overflow-hidden">
              <Image
                src={product.image}
                alt={product.alt}
                class="w-full h-64 object-cover"
                width={800}
                height={800}
                format="webp"
                loading="lazy"
              />
              <span class="absolute top-3 left-3 bg-[#C4A0D8]/20 text-[#9B3A6B] text-xs font-bold px-3 py-1 rounded-full border border-[#C4A0D8]/40">
                💖 Para mamá
              </span>
            </div>
          </a>
          <div class="p-5 space-y-3">
            <h3 class="font-bold text-lg text-gray-900">{product.name}</h3>
            <p class="text-sm text-gray-600">{product.description}</p>
            <p class="text-2xl font-bold text-[#F97316]">
              ${product.price.toLocaleString("es-CO")}
            </p>
            <a
              href="https://wa.me/573102278592?text=Hola!%20Quiero%20un%20regalo%20para%20el%20D%C3%ADa%20de%20las%20Madres%20%F0%9F%8C%B8"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full bg-gradient-to-r from-[#C4A0D8] to-[#E8909A] text-white font-semibold px-4 py-2.5 rounded-full hover:scale-105 transition-all"
            >
              <ion-icon name="logo-whatsapp" class="text-xl" aria-hidden="true"></ion-icon>
              Pedir velita
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Bloque emocional -->
    <div class="max-w-3xl mx-auto mb-12">
      <blockquote class="bg-[#FAF5EE] border-l-4 border-[#C4A0D8] px-8 py-6 rounded-xl">
        <p class="text-xl text-gray-700 italic leading-relaxed text-center">
          "Porque ella guardó cada dibujo, cada abrazo, cada momento.
          Ahora tú puedes guardarle un recuerdo que brilla."
        </p>
      </blockquote>
    </div>

    <!-- CTA Final -->
    <div class="text-center">
      <a
        href="https://wa.me/573102278592?text=Hola!%20Quiero%20crear%20un%20regalo%20especial%20para%20el%20D%C3%ADa%20de%20las%20Madres"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-gradient-to-r from-[#C4A0D8] to-[#E8909A] text-white font-bold px-10 py-5 rounded-full text-lg hover:scale-105 hover:shadow-2xl hover:shadow-pink-300/40 transition-all duration-300"
      >
        <ion-icon name="logo-whatsapp" class="text-2xl" aria-hidden="true"></ion-icon>
        Crear el regalo perfecto para mamá 🌸
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes float-madres {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(-5deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    [style*="float-madres"] { animation: none !important; }
  }
</style>
