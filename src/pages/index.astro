  <!-- Script carrusel memoriales -->
  <script>
    (function () {
      function initMemorialesCarousel() {
        const swiperEl = document.getElementById("memoriales-swiper");
        const prevBtn = document.getElementById("mem-prev");
        const nextBtn = document.getElementById("mem-next");
        const dots = Array.from(document.querySelectorAll(".mem-dot")).filter(
          (dot) => dot instanceof HTMLElement,
        );

        if (!swiperEl) return;

        function updateDots(realIndex) {
          dots.forEach((dot, i) => {
            if (i === realIndex) {
              dot.style.width = "32px";
              dot.style.background = "white";
              dot.setAttribute("aria-selected", "true");
            } else {
              dot.style.width = "8px";
              dot.style.background = "rgba(255,255,255,0.5)";
              dot.setAttribute("aria-selected", "false");
            }
          });
        }

        function waitForSwiper() {
          if ("swiper" in swiperEl && swiperEl.swiper) {
            const swiper = swiperEl.swiper;
            prevBtn?.addEventListener("click", () => swiper.slidePrev());
            nextBtn?.addEventListener("click", () => swiper.slideNext());
            dots.forEach((dot, i) => {
              dot.addEventListener("click", () => swiper.slideToLoop(i));
            });
            swiperEl.addEventListener("swiperslidechange", () => {
              updateDots(swiperEl.swiper.realIndex);
            });
          } else {
            setTimeout(waitForSwiper, 80);
          }
        }

        waitForSwiper();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initMemorialesCarousel);
      } else {
        initMemorialesCarousel();
      }
    })();
  </script>

  <!-- Script carrusel recordatorios -->
  <script>
    (function () {
      function initRecordatoriosCarousel() {
        const swiperEl = document.getElementById("recordatorios-swiper");
        const prevBtn = document.getElementById("rec-prev");
        const nextBtn = document.getElementById("rec-next");
        const dots = Array.from(document.querySelectorAll(".rec-dot")).filter(
          (dot) => dot instanceof HTMLElement,
        );

        if (!swiperEl) return;

        function updateDots(realIndex) {
          dots.forEach((dot, i) => {
            if (i === realIndex) {
              dot.style.width = "32px";
              dot.style.background = "white";
              dot.setAttribute("aria-selected", "true");
            } else {
              dot.style.width = "8px";
              dot.style.background = "rgba(255,255,255,0.5)";
              dot.setAttribute("aria-selected", "false");
            }
          });
        }

        function waitForSwiper() {
          if ("swiper" in swiperEl && swiperEl.swiper) {
            const swiper = swiperEl.swiper;
            prevBtn?.addEventListener("click", () => swiper.slidePrev());
            nextBtn?.addEventListener("click", () => swiper.slideNext());
            dots.forEach((dot, i) => {
              dot.addEventListener("click", () => swiper.slideToLoop(i));
            });
            swiperEl.addEventListener("swiperslidechange", () => {
              updateDots(swiperEl.swiper.realIndex);
            });
          } else {
            setTimeout(waitForSwiper, 80);
          }
        }

        waitForSwiper();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initRecordatoriosCarousel);
      } else {
        initRecordatoriosCarousel();
      }
    })();
  </script>

  <!-- Sección Testimonios -->
  <TestimonialsSection />

  <NewsletterSection />

  <FAQSection />

  <script>
    (function () {
      // Configuración de temporadas — sincronizada con src/data/seasons.ts
      var seasons = [
        { id: "halloween",  sm: 10, sd: 1,  em: 10, ed: 31 },
        { id: "navidad",    sm: 11, sd: 15, em: 12, ed: 31 },
        { id: "dia-ninos",  sm: 3,  sd: 1,  em: 3,  ed: 30 },
        { id: "dia-madres", sm: 5,  sd: 1,  em: 5,  ed: 31 },
      ];

      var now   = new Date();
      var month = now.getMonth() + 1; // 1-12
      var day   = now.getDate();

      var active = seasons.find(function (s) {
        var afterStart = month > s.sm || (month === s.sm && day >= s.sd);
        var beforeEnd  = month < s.em || (month === s.em && day <= s.ed);
        return afterStart && beforeEnd;
      });

      if (active) {
        var block = document.querySelector('[data-season="' + active.id + '"]');
        if (block) block.removeAttribute("hidden");
      }
    })();
  </script>

