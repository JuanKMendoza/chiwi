---
import Layout from "../layouts/Layout.astro";
import Image from "astro/components/Image.astro";
import memorialPortada from "../assets/images/Memorial_personalizado, foto.png";
import memorialSofi from "../assets/images/recordatorio_sofi.webp";
import memorialMafi from "../assets/images/velita_mafi.webp";
import memorialMix from "../assets/images/recordatorio_chiwi_mix_perros_gatitos_v2.webp";
import memorialMixdos from "../assets/images/recordatorio_chiwi_mix_perros_gatitos_v3.webp";
import fotoArtesano from "../assets/images/foto_artesano_chiwi.webp";
import recordatorioMalu from "../assets/images/recordatorio_malu.webp";
import recordatorioDiaMujer from "../assets/images/recordatorio_dia_mujer.webp";
import TestimonialsSection from "../components/TestimonialsSection.astro";

import HeroSection from "../components/HeroSection.astro";
import ProductGrid from "../components/ProductGrid.astro";
import TrustSection from "../components/TrustSection.astro";
import FAQSection from "../components/FAQSection.astro";
import NewsletterSection from "../components/NewsletterSection.astro";
import SeasonNavidad   from "../components/seasons/SeasonNavidad.astro";
import SeasonHalloween from "../components/seasons/SeasonHalloween.astro";
import SeasonDiaNinos  from "../components/seasons/SeasonDiaNinos.astro";
import SeasonMadres    from "../components/seasons/SeasonMadres.astro";
import { products } from "../data/products";

const searchQuery = Astro.url.searchParams.get("search");
const searchResults = searchQuery
  ? products.filter(
      (p) =>
        p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
        p.description.toLowerCase().includes(searchQuery.toLowerCase()) ||
        p.category.some((c) =>
          c.toLowerCase().includes(searchQuery.toLowerCase())
        )
    )
  : [];
---

<Layout
  title="Chiwi Colombia | Velas Kawaii Artesanales Personalizadas - Memoriales para Mascotas"
  description="Velas artesanales kawaii hechas a mano en Colombia. Memoriales únicos para mascotas, regalos personalizados y velas que brillan en la oscuridad. ¡Crea tu vela especial!"
>
  <HeroSection />

  {/* Sección de Confianza — oculta hasta tener datos reales */}

  {searchQuery ? (
    <section id="productos" class="w-full py-16">
      <div class="w-full max-w-7xl mx-auto px-4">
        <div class="mb-8">
          <p class="text-gray-500 text-sm mb-2">Búsqueda activa</p>
          <h2 class="text-3xl font-bold text-gray-900">
            Resultados para: <span class="text-orange-500">"{searchQuery}"</span>
          </h2>
          <a href="/" class="text-sm text-orange-500 hover:underline mt-2 inline-block">← Ver todos los productos</a>
        </div>
        {searchResults.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {searchResults.map((product) => (
              <article class="flex flex-col">
                <a href={'/productos/' + product.slug} class="block w-full relative group">
                  <img
                    src={product.image.src}
                    alt={product.alt}
                    class="w-full h-64 object-cover rounded-xl transition-transform group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="mt-3 space-y-1">
                  <h3 class="font-bold text-lg">{product.name}</h3>
                  <p class="font-semibold text-gray-800">{"$" + product.price.toLocaleString('es-CO')}</p>
                </div>
                <a
                  href={'/productos/' + product.slug}
                  class="mt-3 w-full flex items-center justify-center gap-2 bg-gradient-to-r from-orange-500 to-pink-500 text-white font-semibold px-4 py-2.5 rounded-full shadow-md hover:scale-105 transition-all"
                >
                  <ion-icon name="eye-outline" class="text-xl" aria-hidden="true" />
                  <span class="text-sm">Ver detalles</span>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <p class="text-xl text-gray-600 mb-2">
              No encontramos productos para <strong>"{searchQuery}"</strong>.
            </p>
            <p class="text-gray-500 mb-8">¿Hablamos por WhatsApp? Podemos hacer lo que imagines 💫</p>
            <a
              href="https://wa.me/573102278592"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 bg-gradient-to-r from-orange-500 to-pink-500 text-white font-bold px-8 py-4 rounded-full shadow-xl hover:scale-105 transition-all"
            >
              <ion-icon name="logo-whatsapp" class="text-2xl" />
              Hablemos por WhatsApp
            </a>
          </div>
        )}
      </div>
    </section>
  ) : (
    <ProductGrid />
  )}

<!-- ══ SECCIONES DE TEMPORADA (visibilidad controlada por JS según fecha) ══ -->
<div data-season="halloween"  class="season-block" hidden> <SeasonHalloween /> </div>
